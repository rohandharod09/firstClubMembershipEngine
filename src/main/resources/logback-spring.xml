<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProperty scope="context" name="APP_NAME" source="spring.application.name"
                    defaultValue="membership-engine"/>

    <!-- Console appender with structured MDC fields -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36}
                correlationId=%X{correlationId:-NONE}
                path=%X{requestPath:-} method=%X{requestMethod:-}
                - %msg%n
            </pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <logger name="com.firstclub.membership" level="INFO"/>
    <logger name="org.hibernate.SQL" level="WARN"/>
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="net.javacrumbs.shedlock" level="INFO"/>

    <!-- Lower noise from startup -->
    <logger name="org.springframework.boot.autoconfigure" level="WARN"/>
    <logger name="org.springframework.data.redis" level="WARN"/>

</configuration>
